---
interface Props {
  title: string;
  subtitle: string;
  titleKey?: string;
  subtitleKey?: string;
}
const { title, subtitle, titleKey, subtitleKey } = Astro.props;
---
<section class="page-hero">
  <div class="container">
    <h1 data-i18n={titleKey}>{title}</h1>
    <p data-i18n={subtitleKey}>{subtitle}</p>
  </div>
</section>
