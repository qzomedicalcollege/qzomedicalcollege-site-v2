---
interface Props {
  section: string;
  limit?: number;
  layout?: 'list' | 'cards';
  variant?: 'default' | 'people' | 'specialty';
  category?: string;
  empty?: string;
}
const { section, limit = 30, layout = 'list', variant = 'default', category = '', empty = 'Материалы пока не добавлены.' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<div
  class={`post-list ${layout === 'cards' ? 'cards' : ''} ${variant !== 'default' ? `variant-${variant}` : ''}`}
  data-post-list
  data-section={section}
  data-limit={limit}
  data-layout={layout}
  data-variant={variant}
  data-category={category}
  data-empty={empty}
>
  <div class="empty-state">Загрузка...</div>
</div>
<script type="module" src={`${base}js/publicSite.js`}></script>
