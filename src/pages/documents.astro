---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PostSection from '../components/PostSection.astro';
---
<BaseLayout title="Документы — Қызылорда жоғары медициналық колледжі" active="documents">
  <PageHero title="Документы" subtitle="Официальные документы, лицензии, аккредитация, правила, приказы и файлы для скачивания." />
  <section class="section"><div class="container"><PostSection section="documents" empty="Документы пока не добавлены." /></div></section>
</BaseLayout>
