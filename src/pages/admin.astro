---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Админ-панель — Қызылорда жоғары медициналық колледжі" admin={true}>
  <div class="admin-shell">
    <div class="admin-panel admin-topbar">
      <a class="logo" href={`${base}index.html`}><img src={`${base}assets/logo.png`} alt="Логотип" /><span>Админ-панель V2</span></a>
      <div class="admin-actions">
        <a class="btn btn-muted" href={`${base}index.html`}>На сайт</a>
        <button class="btn btn-danger" id="logoutBtn" type="button" hidden>Выйти</button>
      </div>
    </div>

    <section class="admin-panel login-card" id="loginPanel">
      <h1>Вход в админку</h1>
      <p style="color: var(--muted);">Войдите через Supabase Auth. Пользователь должен быть добавлен в таблицу <code>admin_users</code>.</p>
      <form id="loginForm">
        <div class="form-group"><label>Email</label><input class="input" type="email" id="loginEmail" autocomplete="email" required /></div>
        <div class="form-group"><label>Пароль</label><input class="input" type="password" id="loginPassword" autocomplete="current-password" required /></div>
        <button class="btn btn-primary" type="submit">Войти</button>
      </form>
      <div class="notice" id="loginNotice"></div>
    </section>

    <section class="admin-panel" id="dashboardPanel" hidden>
      <div class="section-header">
        <div>
          <h1 class="section-title">Управление сайтом</h1>
          <p class="section-subtitle">Публикации, документы, расписание и файлы. Теперь есть предпросмотр, быстрые статусы, дублирование, фильтры и улучшенная работа с файлами.</p>
        </div>
      </div>

      <div class="admin-stats" aria-label="Статистика админки">
        <div class="admin-stat"><strong id="statsTotal">0</strong><span>Всего записей</span></div>
        <div class="admin-stat"><strong id="statsPublished">0</strong><span>Опубликовано</span></div>
        <div class="admin-stat"><strong id="statsDrafts">0</strong><span>Черновиков</span></div>
        <div class="admin-stat"><strong id="statsFiles">0</strong><span>Файлов</span></div>
      </div>

      <div class="admin-grid">
        <div class="card">
          <div class="form-card-title">
            <h2 id="formTitle">Новая запись</h2>
            <span class="status draft" id="formModeBadge">создание</span>
          </div>
          <form id="postForm">
            <input type="hidden" id="postId" />
            <div class="form-row">
              <div class="form-group">
                <label>Раздел</label>
                <select class="select" id="sectionInput" required>
                  <option value="news">Новости</option>
                  <option value="announcements">Объявления</option>
                  <option value="about">О колледже</option>
                  <option value="admission">Абитуриентам</option>
                  <option value="students">Студентам</option>
                  <option value="specialties">Специальности</option>
                  <option value="documents">Документы</option>
                  <option value="schedule">Расписание</option>
                  <option value="gallery">Галерея</option>
                  <option value="teachers">Преподаватели</option>
                  <option value="management">Руководство</option>
                  <option value="faq">FAQ</option>
                </select>
              </div>
              <div class="form-group">
                <label>Статус</label>
                <select class="select" id="statusInput">
                  <option value="published">Опубликовано</option>
                  <option value="draft">Черновик</option>
                </select>
              </div>
            </div>

            <div class="form-row compact-row">
              <label class="check-card"><input type="checkbox" id="pinnedInput" /> <span><b>Закрепить</b><small>Показывать выше остальных</small></span></label>
              <label class="check-card"><input type="checkbox" id="importantInput" /> <span><b>Важная запись</b><small>Добавит метку “Важно”</small></span></label>
            </div>

            <div class="form-group"><label>Заголовок</label><input class="input" id="titleInput" required placeholder="Например: Расписание экзаменов" /></div>
            <div class="form-group">
              <label>Категория</label>
              <input class="input" id="categoryInput" list="categorySuggestions" placeholder="Например: Приказы, Практика, Лицензии" />
              <datalist id="categorySuggestions"></datalist>
            </div>

            <div class="section-fields" data-section-fields="teachers management" hidden>
              <div class="form-section-title">Поля карточки сотрудника</div>
              <div class="form-row">
                <div class="form-group"><label>Должность</label><input class="input" id="personPositionInput" placeholder="Например: преподаватель специальных дисциплин" /></div>
                <div class="form-group"><label>Отдел / комиссия</label><input class="input" id="personDepartmentInput" placeholder="Цикловая комиссия, отделение" /></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Стаж</label><input class="input" id="personExperienceInput" placeholder="Например: 12 лет" /></div>
                <div class="form-group"><label>Квалификация / категория</label><input class="input" id="personQualificationInput" placeholder="Высшая категория, магистр и т.д." /></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Email</label><input class="input" type="email" id="personEmailInput" placeholder="name@example.kz" /></div>
                <div class="form-group"><label>Кабинет / контакт</label><input class="input" id="personContactInput" placeholder="Кабинет, телефон, приёмные часы" /></div>
              </div>
            </div>

            <div class="section-fields" data-section-fields="specialties" hidden>
              <div class="form-section-title">Поля специальности</div>
              <div class="form-row">
                <div class="form-group"><label>Код специальности</label><input class="input" id="specialtyCodeInput" placeholder="Например: 09130100" /></div>
                <div class="form-group"><label>Срок обучения</label><input class="input" id="specialtyDurationInput" placeholder="Например: 2 г. 10 мес." /></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Форма обучения</label><input class="input" id="specialtyFormInput" placeholder="Очная" /></div>
                <div class="form-group"><label>Квалификация</label><input class="input" id="specialtyQualificationInput" placeholder="Фельдшер, медсестра, фармацевт" /></div>
              </div>
              <div class="form-group"><label>База поступления</label><input class="input" id="specialtyBasisInput" placeholder="После 9 / 11 класса" /></div>
            </div>

            <div class="section-fields" data-section-fields="gallery" hidden>
              <div class="form-section-title">Поля фотоальбома</div>
              <div class="form-row">
                <div class="form-group"><label>Дата мероприятия</label><input class="input" type="date" id="galleryDateInput" /></div>
                <div class="form-group"><label>Место</label><input class="input" id="galleryLocationInput" placeholder="Колледж, клиническая база, актовый зал" /></div>
              </div>
              <div class="form-group"><label>Участники / аудитория</label><input class="input" id="galleryAudienceInput" placeholder="Студенты, преподаватели, гости" /></div>
            </div>

            <div class="section-fields" data-section-fields="admission announcements" hidden>
              <div class="form-section-title">Поля объявления / приёмной комиссии</div>
              <div class="form-row">
                <div class="form-group"><label>Срок / дедлайн</label><input class="input" id="admissionDeadlineInput" placeholder="Например: до 25 августа" /></div>
                <div class="form-group"><label>Контакт</label><input class="input" id="admissionContactInput" placeholder="Телефон, кабинет, ответственный" /></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Текст кнопки</label><input class="input" id="admissionActionInput" placeholder="Скачать приказ, Открыть форму" /></div>
                <div class="form-group"><label>Ссылка кнопки</label><input class="input" id="admissionActionUrlInput" placeholder="https://..." /></div>
              </div>
            </div>
            <div class="form-group rich-editor-group">
              <label>Текст</label>
              <div class="editor-toolbar" aria-label="Панель форматирования текста">
                <button type="button" class="editor-btn" data-editor-command="formatBlock" data-editor-value="h2">H2</button>
                <button type="button" class="editor-btn" data-editor-command="formatBlock" data-editor-value="h3">H3</button>
                <button type="button" class="editor-btn" data-editor-command="bold"><b>B</b></button>
                <button type="button" class="editor-btn" data-editor-command="italic"><i>I</i></button>
                <button type="button" class="editor-btn" data-editor-command="underline"><u>U</u></button>
                <button type="button" class="editor-btn" data-editor-command="insertUnorderedList">• список</button>
                <button type="button" class="editor-btn" data-editor-command="insertOrderedList">1. список</button>
                <button type="button" class="editor-btn" data-editor-command="createLink">Ссылка</button>
                <button type="button" class="editor-btn" data-editor-action="quote">Цитата</button>
                <button type="button" class="editor-btn" data-editor-action="table">Таблица</button>
                <button type="button" class="editor-btn" data-editor-command="removeFormat">Очистить</button>
              </div>
              <div class="rich-editor" id="contentEditor" contenteditable="true" role="textbox" aria-multiline="true" data-placeholder="Основной текст записи. Можно использовать заголовки, списки, ссылки, таблицы..."></div>
              <textarea class="textarea sr-only-textarea" id="contentInput" tabindex="-1" aria-hidden="true"></textarea>
              <small style="color: var(--muted);">Текст сохраняется как безопасный HTML: заголовки, списки, ссылки, таблицы, цитаты. Скрипты и опасные атрибуты удаляются.</small>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Порядок</label><input class="input" type="number" id="sortInput" value="0" /></div>
              <div class="form-group"><label>Дата публикации</label><input class="input" type="datetime-local" id="publishedAtInput" /></div>
            </div>
            <div class="form-group">
              <label>Файлы</label>
              <input class="input" type="file" id="filesInput" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.jpeg,.png,.webp,.gif" />
              <small style="color: var(--muted);">До 25 МБ на файл. Первое изображение станет превью. Удалённые старые файлы сотрутся из Storage после сохранения.</small>
            </div>
            <div id="existingFiles" class="file-list admin-file-list"></div>
            <div class="admin-actions">
              <button class="btn btn-primary" type="submit" id="saveBtn">Опубликовать</button>
              <button class="btn btn-muted" type="button" id="previewBtn">Предпросмотр</button>
              <button class="btn btn-muted" type="button" id="resetBtn">Сбросить</button>
            </div>
          </form>
          <div class="notice" id="formNotice"></div>
        </div>

        <div class="card">
          <div class="admin-list-head">
            <div>
              <h2>Все записи</h2>
              <p>Фильтруй, редактируй, дублируй и быстро меняй статус.</p>
            </div>
            <button class="btn btn-muted" type="button" id="refreshBtn">Обновить</button>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Раздел</label>
              <select class="select" id="filterSection">
                <option value="">Все разделы</option>
                <option value="news">Новости</option>
                <option value="announcements">Объявления</option>
                <option value="about">О колледже</option>
                <option value="admission">Абитуриентам</option>
                <option value="students">Студентам</option>
                <option value="specialties">Специальности</option>
                <option value="documents">Документы</option>
                <option value="schedule">Расписание</option>
                <option value="gallery">Галерея</option>
                <option value="teachers">Преподаватели</option>
                <option value="management">Руководство</option>
                <option value="faq">FAQ</option>
              </select>
            </div>
            <div class="form-group">
              <label>Статус</label>
              <select class="select" id="filterStatus">
                <option value="">Все</option>
                <option value="published">Опубликовано</option>
                <option value="draft">Черновики</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Категория</label><select class="select" id="filterCategory"><option value="">Все категории</option></select></div>
            <div class="form-group"><label>Поиск</label><input class="input" id="searchInput" placeholder="Заголовок, текст, категория..." /></div>
          </div>
          <div id="postsList"><div class="empty-state">Загрузка...</div></div>
        </div>
      </div>

      <div class="card activity-card">
        <div class="admin-list-head">
          <div>
            <h2>Журнал действий</h2>
            <p>Последние операции в админке: создание, редактирование, публикация, удаление и работа с файлами.</p>
          </div>
          <button class="btn btn-muted" type="button" id="refreshLogBtn">Обновить журнал</button>
        </div>
        <div id="activityLogList"><div class="empty-state">Журнал загрузится после входа.</div></div>
      </div>
    </section>
  </div>

  <dialog class="preview-dialog" id="previewDialog">
    <div class="preview-dialog__head">
      <strong>Предпросмотр записи</strong>
      <button class="btn btn-muted" type="button" id="closePreviewBtn">Закрыть</button>
    </div>
    <div id="previewContent" class="preview-content"></div>
  </dialog>

  <script type="module" src={`${base}js/admin.js`}></script>
</BaseLayout>
