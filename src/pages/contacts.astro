---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---
<BaseLayout title="Контакты — Қызылорда жоғары медициналық колледжі" active="contacts">
  <PageHero title="Контакты" subtitle="Адрес, телефон, email и обратная связь с колледжем." />
  <section class="section">
    <div class="container contacts-grid">
      <div class="card">
        <h3>Қызылорда жоғары медициналық колледжі</h3>
        <p><strong>Адрес:</strong> Қызылорда қ., Ы. Жахаев көш. 18</p>
        <p><strong>Приёмная комиссия:</strong> +7 7242 23-05-13</p>
        <p><strong>Email:</strong> kzmediccollege@mail.kz</p>
        <p><strong>Соцсети:</strong> добавьте официальные ссылки в коде или через будущий раздел настроек.</p>
      </div>
      <div class="map-box">
        <div>
          <h3>Карта</h3>
          <p>Сюда можно вставить iframe Google Maps / 2GIS после публикации сайта.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
