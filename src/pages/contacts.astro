---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const mapUrl = 'https://www.google.com/maps/search/?api=1&query=%D0%9A%D1%8B%D0%B7%D1%8B%D0%BB%D0%BE%D1%80%D0%B4%D0%B0%2C%20%D0%AB.%20%D0%96%D0%B0%D1%85%D0%B0%D0%B5%D0%B2%D0%B0%2018';
---
<BaseLayout title="Контакты — Қызылорда жоғары медициналық колледжі" active="contacts">
  <PageHero title="Контакты" subtitle="Адрес, телефон, email и связь с приёмной комиссией колледжа." titleKey="page.contacts.title" subtitleKey="page.contacts.subtitle" />
  <section class="section">
    <div class="container contacts-grid">
      <div class="card">
        <div class="kicker" data-i18n="contacts.kicker">Связь</div>
        <h2 class="section-title" data-i18n="site.name">Қызылорда жоғары медициналық колледжі</h2>
        <div class="contact-row"><span class="contact-badge">📍</span><div><strong data-i18n="contacts.address">Адрес</strong><p data-i18n="top.address">Қызылорда қ., Ы. Жахаев көшесі, 18</p></div></div>
        <div class="contact-row"><span class="contact-badge">☎</span><div><strong data-i18n="contacts.commission">Приёмная комиссия</strong><p>+7 7242 23-05-13</p></div></div>
        <div class="contact-row"><span class="contact-badge">✉</span><div><strong>Email</strong><p>kzmediccollege@mail.kz</p></div></div>
      </div>
      <div class="map-box upgraded-map">
        <div>
          <h3 data-i18n="contacts.map.title">Карта</h3>
          <p data-i18n="contacts.map.text">Откройте адрес колледжа в карте или используйте его для построения маршрута.</p>
          <p><strong data-i18n="contacts.address">Адрес</strong>: <span data-i18n="top.address">Қызылорда қ., Ы. Жахаев көшесі, 18</span></p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={mapUrl} target="_blank" rel="noopener" data-i18n="contacts.map.open">Открыть карту</a>
            <button class="btn btn-secondary" type="button" data-copy-address data-i18n="contacts.map.copy">Скопировать адрес</button>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script is:inline>
    document.querySelector('[data-copy-address]')?.addEventListener('click', async () => {
      const address = 'Қызылорда қ., Ы. Жахаев көшесі, 18';
      try {
        await navigator.clipboard.writeText(address);
        alert('Адрес скопирован');
      } catch {
        alert(address);
      }
    });
  </script>
</BaseLayout>
