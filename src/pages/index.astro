---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostSection from '../components/PostSection.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Қызылорда жоғары медициналық колледжі" active="home" description="Официальный информационный портал Қызылорда жоғары медициналық колледжі: новости, документы, расписание, абитуриентам и студентам.">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow" data-i18n="home.eyebrow">Официальный сайт колледжа · с 1928 года</span>
        <h1 data-i18n="home.title">Қызылорда жоғары медициналық колледжі</h1>
        <p data-i18n="home.subtitle">Подготовка специалистов для здравоохранения региона: качественное медицинское образование, практическая подготовка и актуальная информация для студентов и абитуриентов.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={`${base}admission.html`} data-i18n="home.cta.admission">Поступающим</a>
          <a class="btn btn-secondary" href={`${base}documents.html`} data-i18n="home.cta.documents">Официальные документы</a>
          <a class="btn btn-ghost" href={`${base}search.html`} data-i18n="home.cta.search">Поиск по сайту</a>
        </div>
      </div>
      <aside class="hero-card" aria-label="Быстрый доступ">
        <img class="mini-logo" src={`${base}assets/logo.png`} alt="Логотип колледжа" />
        <h3 data-i18n="home.quick.title">Быстрый доступ</h3>
        <p data-i18n="home.quick.text">Основные разделы сайта для студентов, абитуриентов и сотрудников колледжа.</p>
        <div class="hero-list">
          <a href={`${base}schedule.html`}><span data-i18n="home.quick.schedule">Расписание</span><span>→</span></a>
          <a href={`${base}documents.html`}><span data-i18n="home.quick.documents">Документы</span><span>→</span></a>
          <a href={`${base}contacts.html`}><span data-i18n="home.quick.contacts">Контакты приёмной комиссии</span><span>→</span></a>
          <a href={`${base}search.html`}><span data-i18n="home.quick.search">Поиск по материалам</span><span>→</span></a>
        </div>
      </aside>
    </div>
  </section>


  <section class="section banner-section">
    <div class="container">
      <div class="section-header compact">
        <div>
          <div class="kicker">Важное</div>
          <h2 class="section-title">Закреплённые объявления</h2>
        </div>
        <a class="btn btn-secondary" href={`${base}announcements.html`}>Все объявления</a>
      </div>
      <PostSection section="announcements" limit={2} layout="cards" empty="Важных объявлений пока нет." />
    </div>
  </section>

  <div class="container stats" aria-label="Статистика колледжа">
    <div class="stat"><strong>1928</strong><span data-i18n="home.stat.founded">год основания</span></div>
    <div class="stat"><strong>2071</strong><span data-i18n="home.stat.students">студент</span></div>
    <div class="stat"><strong>8</strong><span data-i18n="home.stat.specialties">специальностей</span></div>
    <div class="stat"><strong>33</strong><span data-i18n="home.stat.clinics">клинические базы</span></div>
    <div class="stat"><strong>IQAA</strong><span data-i18n="home.stat.accreditation">аккредитация 2021–2026</span></div>
  </div>

  <section class="section white">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="kicker" data-i18n="home.sections.kicker">Разделы сайта</div>
          <h2 class="section-title" data-i18n="home.sections.title">Вся важная информация в одном месте</h2>
          <p class="section-subtitle" data-i18n="home.sections.subtitle">Новости, документы, расписание, информация для поступающих и студентов обновляются через админ-панель.</p>
        </div>
      </div>
      <div class="grid grid-3">
        <a class="card" href={`${base}admission.html`}><div class="icon">01</div><h3 data-i18n="home.card.admission.title">Абитуриентам</h3><p data-i18n="home.card.admission.text">Сроки приёма, список документов, специальности и связь с приёмной комиссией.</p></a>
        <a class="card" href={`${base}students.html`}><div class="icon">02</div><h3 data-i18n="home.card.students.title">Студентам</h3><p data-i18n="home.card.students.text">Учебные материалы, практика, объявления и полезные документы для студентов.</p></a>
        <a class="card" href={`${base}documents.html`}><div class="icon">03</div><h3 data-i18n="home.card.documents.title">Документы</h3><p data-i18n="home.card.documents.text">Лицензии, аккредитация, приказы, правила и файлы для скачивания.</p></a>
        <a class="card" href={`${base}teachers.html`}><div class="icon">04</div><h3>Преподаватели</h3><p>Педагогический состав, цикловые комиссии и методическая работа.</p></a>
        <a class="card" href={`${base}gallery.html`}><div class="icon">05</div><h3>Галерея</h3><p>Фотоальбомы мероприятий, практики, конкурсов и студенческой жизни.</p></a>
        <a class="card" href={`${base}faq.html`}><div class="icon">06</div><h3>FAQ</h3><p>Ответы на частые вопросы абитуриентов, студентов и родителей.</p></a>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="kicker" data-i18n="home.education.kicker">Образование</div>
          <h2 class="section-title" data-i18n="home.education.title">Направления подготовки</h2>
          <p class="section-subtitle" data-i18n="home.education.subtitle">Основные образовательные направления колледжа. Подробные описания можно добавлять и обновлять через админку.</p>
        </div>
        <a class="btn btn-secondary" href={`${base}specialties.html`} data-i18n="home.education.all">Все специальности</a>
      </div>
      <div class="grid grid-3">
        <div class="card"><div class="icon">⚕</div><h3 data-i18n="home.spec.nursing">Сестринское дело</h3><p data-i18n="home.spec.nursing.text">Практико-ориентированная подготовка специалистов сестринского дела.</p></div>
        <div class="card"><div class="icon">+</div><h3 data-i18n="home.spec.medical">Лечебное дело</h3><p data-i18n="home.spec.medical.text">Базовые медицинские компетенции и подготовка среднего медицинского звена.</p></div>
        <div class="card"><div class="icon">↗</div><h3 data-i18n="home.spec.practice">Клиническая практика</h3><p data-i18n="home.spec.practice.text">Обучение с использованием клинических баз и практических занятий.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="kicker" data-i18n="home.news.kicker">Новости</div>
          <h2 class="section-title" data-i18n="home.news.title">Последние объявления и события</h2>
          <p class="section-subtitle" data-i18n="home.news.subtitle">Актуальные новости колледжа и важные уведомления.</p>
        </div>
        <a class="btn btn-secondary" href={`${base}news.html`} data-i18n="home.news.all">Все новости</a>
      </div>
      <PostSection section="news" limit={3} layout="cards" empty="Новостей пока нет." />
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="kicker">Колледж в кадре</div>
          <h2 class="section-title">Последние фотоальбомы</h2>
          <p class="section-subtitle">Мероприятия, практика и студенческая жизнь колледжа.</p>
        </div>
        <a class="btn btn-secondary" href={`${base}gallery.html`}>Открыть галерею</a>
      </div>
      <PostSection section="gallery" limit={3} layout="cards" empty="Фотоальбомы пока не добавлены." />
    </div>
  </section>

  <section class="section white">
    <div class="container grid grid-2">
      <div class="card">
        <div class="kicker" data-i18n="home.admission.kicker">Поступление</div>
        <h2 class="section-title" data-i18n="home.admission.title">Приёмная комиссия</h2>
        <p data-i18n="home.admission.text">Получите информацию о поступлении, документах и специальностях. При необходимости свяжитесь с приёмной комиссией колледжа.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={`${base}admission.html`} data-i18n="nav.admission">Абитуриентам</a>
          <a class="btn btn-secondary" href={`${base}contacts.html`} data-i18n="nav.contacts">Контакты</a>
        </div>
      </div>
      <div class="card">
        <div class="kicker" data-i18n="home.files.kicker">Файлы</div>
        <h2 class="section-title" data-i18n="home.files.title">Документы и расписание</h2>
        <p data-i18n="home.files.text">PDF, Word, Excel и другие материалы доступны в соответствующих разделах. Файлы скачиваются напрямую с сайта.</p>
        <div class="hero-actions">
          <a class="btn btn-secondary" href={`${base}documents.html`} data-i18n="nav.documents">Документы</a>
          <a class="btn btn-secondary" href={`${base}schedule.html`} data-i18n="nav.schedule">Расписание</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
