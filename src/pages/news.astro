---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PostSection from '../components/PostSection.astro';
---
<BaseLayout title="Новости — Қызылорда жоғары медициналық колледжі" active="news">
  <PageHero title="Новости" subtitle="Официальные новости, события и объявления колледжа." />
  <section class="section"><div class="container"><PostSection section="news" layout="cards" empty="Новостей пока нет." /></div></section>
</BaseLayout>
