---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Страница не найдена — Қызылорда жоғары медициналық колледжі">
  <section class="page-hero">
    <div class="container">
      <h1 data-i18n="page.404.title">Страница не найдена</h1>
      <p data-i18n="page.404.subtitle">Запрошенная страница отсутствует или была перемещена.</p>
      <div class="hero-actions" style="margin-top: 24px;">
        <a class="btn btn-primary" href={`${base}index.html`} data-i18n="common.home">На главную</a>
        <a class="btn btn-secondary" href={`${base}contacts.html`} data-i18n="nav.contacts">Контакты</a>
      </div>
    </div>
  </section>
</BaseLayout>
