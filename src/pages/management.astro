---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PostSection from '../components/PostSection.astro';
---
<BaseLayout title="Руководство — Қызылорда жоғары медициналық колледжі" active="management" description="Руководство колледжа, заместители директора и заведующие отделениями.">
  <PageHero title="Руководство" subtitle="Администрация колледжа, заместители директора, заведующие отделениями и ответственные подразделения." />
  <section class="section">
    <div class="container grid grid-3">
      <div class="card"><div class="icon">🏛️</div><h3>Директор</h3><p>Стратегическое развитие, внешние связи и общее управление колледжем.</p></div>
      <div class="card"><div class="icon">🧩</div><h3>Заместители</h3><p>Учебная, воспитательная, методическая и практическая работа.</p></div>
      <div class="card"><div class="icon">📌</div><h3>Отделения</h3><p>Организация учебного процесса, расписания, практики и сопровождения студентов.</p></div>
    </div>
  </section>
  <section class="section white">
    <div class="container">
      <div class="section-header"><div><div class="kicker">Администрация</div><h2 class="section-title">Состав руководства</h2><p class="section-subtitle">Карточки выводятся в отдельном официальном формате: должность, направление, контакты и описание.</p></div></div>
      <PostSection section="management" layout="cards" variant="people" empty="Информация о руководстве пока не добавлена." />
    </div>
  </section>
</BaseLayout>
