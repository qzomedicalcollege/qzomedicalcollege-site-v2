---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Поиск — Қызылорда жоғары медициналық колледжі" active="search" description="Поиск по новостям, документам, расписанию и материалам сайта колледжа.">
  <PageHero title="Поиск по сайту" subtitle="Найдите новости, документы, расписание и материалы для студентов или абитуриентов." titleKey="page.search.title" subtitleKey="page.search.subtitle" />

  <section class="section">
    <div class="container">
      <div class="search-panel card">
        <div>
          <label class="search-label" for="siteSearchInput" data-i18n="search.label.query">Что ищем?</label>
          <input id="siteSearchInput" class="search-input" type="search" placeholder="Например: расписание, лицензия, приём, практика" data-i18n-placeholder="search.placeholder" autocomplete="off" />
        </div>
        <div>
          <label class="search-label" for="siteSearchSection" data-i18n="search.label.section">Раздел</label>
          <select id="siteSearchSection" class="search-select">
            <option value="" data-i18n="search.all">Все разделы</option>
            <option value="news" data-i18n="nav.news">Новости</option>
            <option value="announcements" data-i18n="nav.announcements">Объявления</option>
            <option value="about" data-i18n="nav.about">О колледже</option>
            <option value="admission" data-i18n="nav.admission">Абитуриентам</option>
            <option value="students" data-i18n="nav.students">Студентам</option>
            <option value="specialties" data-i18n="nav.specialties">Специальности</option>
            <option value="documents" data-i18n="nav.documents">Документы</option>
            <option value="schedule" data-i18n="nav.schedule">Расписание</option>
            <option value="gallery" data-i18n="nav.gallery">Галерея</option>
            <option value="teachers" data-i18n="nav.teachers">Преподаватели</option>
            <option value="management" data-i18n="nav.management">Руководство</option>
            <option value="faq" data-i18n="nav.faq">FAQ</option>
          </select>
        </div>
        <button class="btn btn-primary" id="siteSearchButton" type="button" data-i18n="search.button">Искать</button>
      </div>

      <div class="quick-pages" aria-label="Быстрые ссылки">
        <a href={`${base}admission.html`} data-i18n="nav.admission">Абитуриентам</a>
        <a href={`${base}documents.html`} data-i18n="nav.documents">Документы</a>
        <a href={`${base}schedule.html`} data-i18n="nav.schedule">Расписание</a>
        <a href={`${base}announcements.html`} data-i18n="nav.announcements">Объявления</a>
        <a href={`${base}gallery.html`} data-i18n="nav.gallery">Галерея</a>
        <a href={`${base}contacts.html`} data-i18n="nav.contacts">Контакты</a>
      </div>

      <div class="search-summary" id="siteSearchSummary" data-i18n="search.summary">Введите запрос или выберите раздел.</div>
      <div class="search-results" id="siteSearchResults">
        <div class="empty-state" data-i18n="search.empty">Последние опубликованные материалы появятся здесь.</div>
      </div>
    </div>
  </section>

  <script type="module" src={`${base}js/search.js`}></script>
</BaseLayout>
