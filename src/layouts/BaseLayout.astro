---
interface Props {
  title: string;
  description?: string;
  active?: string;
  admin?: boolean;
}
const { title, description = 'Қызылорда жоғары медициналық колледжі — ресми ақпараттық сайт.', active = '', admin = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const nav = [
  ['about', 'О колледже', 'about.html'],
  ['admission', 'Абитуриентам', 'admission.html'],
  ['specialties', 'Специальности', 'specialties.html'],
  ['students', 'Студентам', 'students.html'],
  ['documents', 'Документы', 'documents.html'],
  ['schedule', 'Расписание', 'schedule.html'],
  ['news', 'Новости', 'news.html'],
];
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}assets/logo.png`} />
    <link rel="icon" type="image/png" href={`${base}assets/logo.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;650;750;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body class={admin ? 'admin-body' : ''}>
    <a class="skip-link" href="#main">Перейти к содержанию</a>
    {!admin && (
      <header class="site-header">
        <div class="topbar">
          <div class="container">
            <span>Қызылорда қ., Ы. Жахаев көш. 18</span>
            <span>Қабылдау комиссиясы: +7 7242 23-05-13 · kzmediccollege@mail.kz</span>
          </div>
        </div>
        <div class="container navbar">
          <a class="logo" href={`${base}index.html`} aria-label="Главная">
            <img src={`${base}assets/logo.png`} alt="Логотип колледжа" />
            <span>Қызылорда жоғары медициналық колледжі</span>
          </a>
          <button class="menu-btn" data-menu-btn type="button" aria-label="Открыть меню">☰</button>
          <nav>
            <ul class="nav-links" data-nav-links>
              {nav.map(([key, label, href]) => (
                <li><a class={active === key ? 'active' : ''} href={`${base}${href}`}>{label}</a></li>
              ))}
              <li><a class="nav-cta" href={`${base}contacts.html`}>Контакты</a></li>
            </ul>
          </nav>
        </div>
      </header>
    )}
    <main id="main">
      <slot />
    </main>
    {!admin && (
      <footer class="site-footer">
        <div class="container">
          <div class="footer-grid">
            <div>
              <h3>Қызылорда жоғары медициналық колледжі</h3>
              <p>Медициналық білім, тәжірибелік дайындық және қоғамдық денсаулық сақтау саласына кадрлар даярлау.</p>
            </div>
            <div>
              <h4>Бөлімдер</h4>
              <p><a href={`${base}admission.html`}>Абитуриентам</a></p>
              <p><a href={`${base}documents.html`}>Документы</a></p>
              <p><a href={`${base}news.html`}>Новости</a></p>
            </div>
            <div>
              <h4>Контакты</h4>
              <p>Қызылорда қ., Ы. Жахаев көш. 18</p>
              <p>+7 7242 23-05-13</p>
              <p>kzmediccollege@mail.kz</p>
            </div>
          </div>
          <div class="footer-bottom">© 2026 Қызылорда жоғары медициналық колледжі. Барлық құқықтар қорғалған.</div>
        </div>
      </footer>
    )}
    <script is:inline>
      const btn = document.querySelector('[data-menu-btn]');
      const links = document.querySelector('[data-nav-links]');
      btn?.addEventListener('click', () => links?.classList.toggle('open'));
      links?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => links?.classList.remove('open')));
    </script>
  </body>
</html>
